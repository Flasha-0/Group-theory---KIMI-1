@echo off
chcp 65001 > nul
title تشغيل الموقع التفاعلي - نظرية الزمر

echo ======================================================
echo          الموقع التفاعلي لكتاب نظرية الزمر
echo ======================================================
echo.
echo [1/2] جاري التحقق من المجلدات وتثبيت التبعيات إذا لزم الأمر...

if not exist node_modules (
    echo مجلد التبعيات (node_modules) غير موجود. جاري التحميل...
    call npm install --no-audit --no-fund
) else (
    echo التبعيات مثبتة بالفعل.
)

echo.
echo [2/2] جاري تشغيل الخادم المحلي وفتح الموقع في المتصفح...
echo سيتم فتح نافذة المتصفح تلقائياً خلال لحظات.
echo لتوقيف التشغيل، يمكنك إغلاق هذه النافذة.
echo ------------------------------------------------------
echo.

call npm run dev -- --open

pause
